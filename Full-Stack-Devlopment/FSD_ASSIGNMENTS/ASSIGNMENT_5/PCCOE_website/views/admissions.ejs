<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Pimpri Chinchwad College Of engineering (PCCOE)  | Admissions</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container my-5">
    <h1 class="mb-4">Admissions 2026-27</h1>
    
    <!-- Your Graduation / Campus Image -->
    <div class="text-center mb-5">
      <img src="/images/graduation.jpg" class="img-fluid rounded shadow" alt="Graduation Ceremony">   <!-- Your image -->
      <p class="mt-3 text-muted">Join the next batch of successful PCCOE graduates</p>
    </div>

    <% if (submitted) { %>
      <div class="alert alert-success">Application submitted successfully!</div>
    <% } %>

    <form action="/submit-application" method="POST" class="row g-3">
      <div class="col-md-6">
        <label class="form-label">Full Name</label>
        <input type="text" name="name" class="form-control" required>
      </div>
      <div class="col-md-6">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control" required>
      </div>
      <div class="col-md-6">
        <label class="form-label">Phone</label>
        <input type="tel" name="phone" class="form-control" required>
      </div>
      <div class="col-md-6">
        <label class="form-label">Course</label>
        <select name="course" class="form-select" required>
          <option value="">Choose Course...</option>
          <% courses.forEach(course => { %>
            <option value="<%= course.name %>"><%= course.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-12">
        <button type="submit" class="btn btn-primary btn-lg">Submit Application</button>
      </div>
    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>