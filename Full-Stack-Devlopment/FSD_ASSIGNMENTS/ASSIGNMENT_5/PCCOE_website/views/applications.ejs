<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Pimpri Chinchwad College Of engineering (PCCOE)  | Applications</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container my-5">
    <h1>Submitted Applications (<%= applications.length %>)</h1>
    <% if (applications.length === 0) { %>
      <p class="text-muted">No applications yet. Submit one from the Admissions page!</p>
    <% } else { %>
      <table class="table table-striped">
        <thead>
          <tr>
            <th>Date</th>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Course</th>
          </tr>
        </thead>
        <tbody>
          <% applications.forEach(app => { %>
            <tr>
              <td><%= app.date %></td>
              <td><%= app.name %></td>
              <td><%= app.email %></td>
              <td><%= app.phone %></td>
              <td><%= app.course %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>