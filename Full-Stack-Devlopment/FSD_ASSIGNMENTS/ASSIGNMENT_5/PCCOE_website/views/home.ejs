<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Pimpri Chinchwad College Of engineering (PCCOE) | Home</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .hero {
      background-image: url('/images/hero.jpeg');   /* ← Change to your hero image name */
      background-size: cover;
      background-position: center;
      height: 90vh;
      min-height: 600px;
    }
    .hero-overlay {
      background: rgba(0, 0, 0, 0.45);
    }
  </style>
</head>
<body>
  <%- include('partials/navbar') %>

  <!-- Hero Banner - Your Image -->
  <div class="hero d-flex align-items-center text-white">
    <div class="hero-overlay w-100 h-100 d-flex align-items-center">
      <div class="container text-center">
        <h1 class="display-3 fw-bold">Welcome to Pimpri Chinchwad College Of Engineering</h1>
        <p class="lead fs-3 mb-4">Pune, Maharashtra</p>
        <a href="/admissions" class="btn btn-light btn-lg px-5 py-3">Apply Now</a>
      </div>
    </div>
  </div>

  <div class="container my-5">
    <h2 class="text-center mb-5">Life at Pimpri Chinchwad College Of Engineering</h2>
    <div class="row g-4">
      <div class="col-md-6">
        <img src="/images/students.jpg" class="img-fluid rounded shadow" alt="Students studying">   <!-- Your image -->
      </div>
      <div class="col-md-6">
        <img src="/images/campus.jpg" class="img-fluid rounded shadow" alt="College Campus">         <!-- Your image -->
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>