
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Pimpri Chinchwad College Of engineering (PCCOE)  | Courses</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="container my-5">
    <h1 class="mb-4">Our Courses</h1>
    <div class="text-center mb-5">
  <img src="/images/campus.jpg" class="img-fluid rounded shadow" alt="College Campus">
</div>
    <div class="row">
      <% courses.forEach(course => { %>
        <div class="col-md-6 mb-4">
          <div class="card">
            <div class="card-body">
              <h5><%= course.name %></h5>
              <p><%= course.desc %></p>
              <span class="badge bg-success"><%= course.duration %></span>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>