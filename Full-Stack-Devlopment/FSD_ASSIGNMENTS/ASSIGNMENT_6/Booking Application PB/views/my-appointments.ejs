<%- include('partials/header') %>
<h2>My Appointments</h2>
<% if (appointments && appointments.length > 0) { %>
<table class="table table-hover">
  <thead class="table-dark">
    <tr>
      <th>Vehicle</th>
      <th>Date</th>
      <th>Time</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% appointments.forEach(appointment => { %>
      <tr>
        <td><%= appointment.vehicle.title %></td>
        <td><%= new Date(appointment.date).toLocaleDateString('en-IN') %></td>
        <td><%= appointment.time %></td>
        <td><span class="badge bg-<%= appointment.status === 'pending' ? 'warning' : 'success' %>"><%= appointment.status.toUpperCase() %></span></td>
      </tr>
    <% }) %>
  </tbody>
</table>
<% } else { %>
  <p class="text-muted">No appointments yet. Start booking from vehicle details!</p>
<% } %>
<%- include('partials/footer') %>