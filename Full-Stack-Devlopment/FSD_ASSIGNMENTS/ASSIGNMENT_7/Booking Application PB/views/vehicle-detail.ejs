<%- include('partials/header') %>

<div class="row mt-4">
  <div class="col-md-6">
    <img src="<%= vehicle.image %>" 
         class="img-fluid rounded shadow" 
         alt="<%= vehicle.title %>"
         onerror="this.src='https://via.placeholder.com/600x400?text=Image+Not+Found'">
  </div>
  
  <div class="col-md-6">
    <h1><%= vehicle.title %></h1>
    <h2 class="text-success">₹<%= vehicle.price.toLocaleString('en-IN') %></h2>
    <p><strong>Year:</strong> <%= vehicle.year %> | <strong>Mileage:</strong> <%= vehicle.mileage %> km</p>
    <p><%= vehicle.description %></p>
    
    <% if (user) { %>
      <a href="/appointments/book/<%= vehicle._id %>" class="btn btn-success btn-lg mt-3">
        Book Test Drive / Inspection
      </a>
    <% } else { %>
      <a href="/login" class="btn btn-warning btn-lg mt-3">Login to Book Appointment</a>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>