<%- include('partials/header') %>
<h2>Book Appointment for <span class="text-primary"><%= vehicle.title %></span></h2>
<form action="/appointments/book/<%= vehicle._id %>" method="POST" class="mt-4">
  <div class="mb-3">
    <label class="form-label">Date</label>
    <input type="date" name="date" class="form-control" required>
  </div>
  <div class="mb-3">
    <label class="form-label">Time</label>
    <input type="time" name="time" class="form-control" required>
  </div>
  <button type="submit" class="btn btn-success btn-lg">Confirm Booking</button>
</form>
<%- include('partials/footer') %>